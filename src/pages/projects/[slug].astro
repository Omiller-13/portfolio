---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusColor: Record<string, string> = {
  complete: "#39ffa0",
  "in progress": "#f0c94a",
  ongoing: "#7d8a9c",
};
---

<BaseLayout title={`${project.data.title} — Owen Miller`}>
  <article class="project">
    <a href="/projects" class="back">← back to projects</a>

    <header class="project-header">
      <p class="eyebrow">// project</p>
      <h1>{project.data.title}</h1>
      <p class="project-desc">{project.data.description}</p>
      <div class="project-meta">
        <span
          class="status"
          style={`color: ${statusColor[project.data.status]}`}
        >
          // {project.data.status}
        </span>
        <ul class="tags">
          {project.data.tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      </div>
    </header>

    <div class="project-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .project {
    max-width: 780px;
    margin: var(--space-7) auto;
    padding: 0 var(--space-4);
  }

  .back {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    display: inline-block;
    margin-bottom: var(--space-4);
    transition: color 0.2s ease;
  }
  .back:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .project-header {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  h1 {
    font-size: var(--fs-2xl);
    margin: 0;
  }

  .project-desc {
    color: var(--color-text-muted);
    max-width: 65ch;
    margin: 0;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .status {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    white-space: nowrap;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2px var(--space-2);
  }

  .project-content {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  :global(.project-content h2) {
    font-size: var(--fs-lg);
    margin-top: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  :global(.project-content p) {
    color: var(--color-text-muted);
    max-width: 70ch;
  }

  :global(.project-content ul) {
    color: var(--color-text-muted);
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.project-content a) {
    color: var(--color-accent);
  }

  :global(.project-content img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    display: block;
    margin: var(--space-2) 0;
  }

  @media (max-width: 680px) {
    h1 { font-size: var(--fs-lg); }
  }
</style>
