---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Your Name — Portfolio">
  <section class="hero">
    --- import BaseLayout from '../layouts/BaseLayout.astro'; ---
    <BaseLayout title="Owen Miller — Portfolio">
      <section class="hero">
        <p class="eyebrow">// engineering portfolio — work in progress</p>
        <h1>Hi, I'm Owen.</h1>
        <p class="lede">
          Senior Electrical Engineering student at the University of Maryland. EE intern at Lockheed Martin RMS
          This site will showcase some of my EE and hardware
          projects - currently under construction. Check back soon ! 
		  Contact me at: omiller@umd.edu with any questions !!
        </p>
      </section>
    </BaseLayout>

    <style>
      .hero {
        max-width: var(--max-width);
        margin: var(--space-7) auto 0;
        padding: 0 var(--space-4);
      }
      .eyebrow {
        font-family: var(--font-mono);
        color: var(--color-accent);
        font-size: var(--fs-sm);
      }
      h1 {
        font-size: var(--fs-3xl);
        margin: var(--space-3) 0;
      }
      .lede {
        color: var(--color-text-muted);
        font-size: var(--fs-lg);
        max-width: 60ch;
      }
    </style>
