---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Owen Miller — Portfolio">

  <!-- Hero -->
  <section class="hero">
    <p class="eyebrow">// engineering portfolio</p>
    <h1>Hi, I'm Owen.</h1>
  </section>

  <!-- About -->
  <section class="about">
    <div class="about-photo-wrap">
      <img
        src="/Headshot.jpg"
        alt="Owen Miller"
        class="about-photo"
        width="400"
        height="500"
        loading="eager"
      />
    </div>
    <div class="about-text">
      <p class="eyebrow">// About me</p>
      <p>
        I'm a senior EE student at the University of Maryland and an EE intern
        at Lockheed Martin in Syracuse, New York. I focus on RF, test, and
        hardware engineering.
      </p>
      <p>
        Outside engineering, I'm usually still building (or taking apart)
        something. This site showcases a few of the projects I've worked
        on over my time in engineering.
      </p>
      <a href="/projects" class="btn">View Projects</a>
      <a href="/resume" class="btn">View Resume</a>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact">
    <h2>Contact</h2>
    <p class="muted">
      If you'd like to reach me, email
      <a href="mailto:omiller@umd.edu">omiller@umd.edu</a>
    </p>
    <ul class="contact-list">
      <li>LinkedIn: <a href="https://linkedin.com/in/owenmiller13" target="_blank" rel="noopener noreferrer">linkedin.com/in/owenmiller13</a></li>
      <li>GitHub: <a href="https://github.com/Omiller-13" target="_blank" rel="noopener noreferrer">github.com/Omiller-13</a></li>
    </ul>
  </section>

</BaseLayout>

<style>
  /* ── Layout only — no font or color declarations ── */

  .hero {
    max-width: var(--max-width);
    margin: var(--space-7) auto 0;
    padding: 0 var(--space-4);
  }
  .hero h1 {
    font-size: var(--fs-3xl);
    margin-top: var(--space-3);
  }

  .about {
    max-width: var(--max-width);
    margin: var(--space-7) auto;
    padding: 0 var(--space-4);
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-7);
    align-items: start;
  }
 .about-photo-wrap {
  position: sticky;
  top: var(--space-4);
  max-height: 480px;
}

.about-photo {
  width: 100%;
  height: 480px;
  display: block;
  border-radius: var(--radius);
  border: 1px solid var(--color-border);
  object-fit: cover;
  object-position: center top;
}
  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact {
    max-width: var(--max-width);
    margin: var(--space-7) auto;
    padding: 0 var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .contact h2 { font-size: var(--fs-2xl); }
  .muted { color: var(--color-text-muted); }
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--color-text-muted);
  }
  .contact-list li {
    padding: var(--space-2) 0;
    border-top: 1px solid var(--color-border);
  }
  .contact-list a { margin-left: var(--space-2); }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 680px) {
    .hero h1 { font-size: var(--fs-2xl); }
    .about {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .about-photo-wrap {
      position: static;
      max-width: 220px;
    }
  }
  .hero-actions {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-4);
  flex-wrap: wrap;
}

.btn {
  display: inline-block;
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius);
  color: var(--color-accent);
  font-family: var(--font-mono);
  font-size: var(--fs-sm);
  transition: background 0.2s ease, color 0.2s ease;
}
.btn:hover {
  background: var(--color-accent);
  color: var(--color-bg);
  text-decoration: none;
}

.btn-ghost {
  border-color: var(--color-border);
  color: var(--color-text-muted);
}
.btn-ghost:hover {
  background: var(--color-border);
  color: var(--color-text);
}
</style>