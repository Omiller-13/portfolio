---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('fun');
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Random & Fun — Owen Miller">
  <section class="fun">
    <p class="eyebrow">// random & fun</p>
    <h1>Fun outside engineering !</h1>
    <p class="subtitle">
      Side projects and adventures. Click on a link to learn more.
    </p>

    <ul class="entry-list">
      {entries.map((entry) => (
        <li class="entry-item">
          <a href={`/fun/${entry.id}`} class="entry-link">
            <div class="entry-header">
              <h2>{entry.data.title}</h2>
              <span class="date">
                {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </span>
            </div>
            <p class="entry-desc">{entry.data.description}</p>
            <ul class="tags">
              {entry.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .fun {
    max-width: var(--max-width);
    margin: var(--space-7) auto;
    padding: 0 var(--space-4);
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: var(--space-3) 0 0;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-top: var(--space-3);
    max-width: 60ch;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: flex;
    flex-direction: column;
  }

  .entry-item {
    border-top: 1px solid var(--color-border);
    transition: border-color 0.2s ease;
  }

  .entry-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .entry-item:has(.entry-link:hover) {
    border-color: var(--color-accent);
  }

  .entry-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    color: inherit;
    text-decoration: none;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .entry-header h2 {
    font-size: var(--fs-lg);
    margin: 0;
    transition: color 0.2s ease;
  }

  .entry-link:hover h2 {
    color: var(--color-accent);
  }

  .date {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-desc {
    color: var(--color-text-muted);
    max-width: 70ch;
    margin: 0;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2px var(--space-2);
  }

  @media (max-width: 680px) {
    h1 { font-size: var(--fs-2xl); }

    .entry-header {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>