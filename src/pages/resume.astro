---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Owen Miller">
  <section class="resume">
    <div class="resume-header">
      <div>
        <p class="eyebrow">// Resume</p>
        <h1></h1>
      </div>
      <a href="/resume.pdf" download class="btn">Download PDF</a>
    </div>

    <div class="pdf-wrap">
      <object
        data="/resume.pdf"
        type="application/pdf"
        class="pdf-embed"
        aria-label="Owen Miller resume"
      >
        <div class="pdf-fallback">
          <p>Your browser can't display PDFs inline.</p>
          <a href="/resume.pdf" download class="btn">Download Resume</a>
        </div>
      </object>
    </div>
  </section>
</BaseLayout>

<style>
  .resume {
    max-width: var(--max-width);
    margin: var(--space-7) auto;
    padding: 0 var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-4);
  }

  h1 {
    font-size: var(--fs-2xl);
    margin: var(--space-2) 0 0;
  }

  .pdf-wrap {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .pdf-embed {
    width: 100%;
    height: 85vh;
    display: block;
    background: var(--color-bg-surface);
  }

  .pdf-fallback {
    padding: var(--space-5);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-muted);
  }

  .btn {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }
  .btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
  }

  @media (max-width: 680px) {
    .resume-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .pdf-embed {
      height: 60vh;
    }
  }
</style>